# ===== FUUDELIVERY Production Configuration =====
# Copy this to .env and fill in your values

# App
PORT=3000
GO_ENV=production
JWT_SECRET=change-this-to-a-random-64-char-string
API_BASE_URL=https://fuudelivery-api.onrender.com
APP_URL=https://fuudelivery-web.onrender.com

# PostgreSQL (Supabase)
DB_CONNECTION_STRING=postgresql://postgres:password@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# MongoDB Atlas
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/fuudelivery?retryWrites=true&w=majority
MONGO_DATABASE=fuudelivery
PAYMENT_MONGO_DATABASE=fuudelivery_payments

# Redis (optional - falls back to internal Go channels)
REDIS_URL=redis://default:password@host:port

# AbacatePay - Brazilian payments (PIX + Card)
ABACATE_PAY_API_KEY=abc_your_api_key_here
ABACATE_PAY_WEBHOOK_SECRET=whsec_your_webhook_secret

# PIX Key for manual transfers
PIX_KEY=your-pix-key@email.com
MERCHANT_NAME=Fuudelivery
MERCHANT_CITY=SaoPaulo

# Queue names (for reference, no longer RabbitMQ)
RABBIT_DELIVERY_QUEUE=MS_DELIVERY_QUEUE
RABBIT_ORDER_QUEUE=RABBIT_ORDER_QUEUE

# Internal service URLs (same monolith)
URL_GET_ESTABLISHMENT_ID=http://localhost:3000/establishments/%d
URL_CHECK_ESTABLISHMENT_OPEN=http://localhost:3000/establishments/%d/is-open
